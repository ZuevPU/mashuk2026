PORT=8080
DATABASE_URL=postgresql://user:password@localhost:5432/mashuk?sslmode=disable

# Production: set SKIP_VK_SIGN=false and provide real VK_APP_SECRET
VK_APP_SECRET=your_vk_app_secret_here
SKIP_VK_SIGN=true

# Production: restrict to your frontend/admin origins
CORS_ORIGIN=*

# Production: change from dev-admin-secret (startup fails if NODE_ENV=production)
ADMIN_SECRET=dev-admin-secret

# Required for real VK push notifications (community service token)
VK_SERVICE_TOKEN=

# Public base URL for uploaded photos (required in production)
PUBLIC_URL=http://localhost:8080

# GigaChat (roadmap E) — never commit real credentials
# GIGACHAT_CREDENTIALS=base64_client_id_secret
# GIGACHAT_SCOPE=GIGACHAT_API_PERS

