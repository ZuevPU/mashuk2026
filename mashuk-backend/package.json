{
  "name": "mashuk-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "node --import tsx --test src/tests/*.test.ts",
    "test:e2e": "node --import tsx --test src/tests/e2e-flow.test.ts",
    "test:vk-auth": "node --import tsx --test src/tests/vkAuthStrict.test.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "npm run db:push && npm run db:seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^26.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^6.0.3",
    "drizzle-kit": "^0.31.10",
    "supertest": "^7.1.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  },
  "type": "module"
}