# Timeweb Apps → mashuk-backend → Переменные окружения
# Заполните значения в <> и загрузите в панель Timeweb

PORT=8080
NODE_ENV=production

# PostgreSQL из панели Timeweb (Базы данных → строка подключения)
DATABASE_URL=postgresql://gen_user:<ПАРОЛЬ>@85.198.80.180:5432/default_db

# VK Mini App → dev.vk.com → Защищённый ключ
SKIP_VK_SIGN=false
VK_APP_SECRET=<КЛЮЧ_ИЗ_VK>

# Уникальный секрет для админки (НЕ dev-admin-secret!)
# Тот же значение потом укажите в админке как VITE_ADMIN_TOKEN
ADMIN_SECRET=<УНИКАЛЬНЫЙ_СЕКРЕТ>

# URL frontend и admin через запятую, без пробелов
CORS_ORIGIN=https://zuevpu-mashuk2026-dc9b.twc1.net,https://zuevpu-mashuk2026-9a9a.twc1.net

# Публичный URL backend (для ссылок на загруженные фото)
PUBLIC_URL=https://zuevpu-mashuk2026-e75d.twc1.net

# Push-уведомления VK (можно оставить пустым, если push не нужен)
VK_SERVICE_TOKEN=

# Только при ПЕРВОМ деплое на пустую БД — создаст тестовые данные
# После успешного деплоя удалите эту строку или поставьте false
AUTO_SEED=true
